{
  "name": "dynasty-launcher",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "Business provisioning engine — tier-scoped docs, code, deploy, and integration attempts (see /maturity and TIER_MODULES in api/provision.js)",
  "scripts": {
    "verify:product": "node scripts/verify-product-alignment.mjs",
    "test:validate": "node scripts/validate-smoke.mjs",
    "test:catalog": "node scripts/smoke-catalog.mjs",
    "test:tenants": "node scripts/smoke-tenants.mjs",
    "test:activation": "node scripts/smoke-activation.mjs",
    "test:events": "node scripts/smoke-events.mjs",
    "test:workflows": "node scripts/smoke-workflows.mjs",
    "test:billing": "node scripts/smoke-billing.mjs",
    "test:generated-repair": "node scripts/generated-repo-regression.mjs",
    "test:site-links": "node scripts/check-site-links.mjs",
    "test:prompts": "npx --yes promptfoo@0.120.19 eval -c promptfooconfig.yaml",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "npm run verify:product && npm run test:validate && npm run test:catalog && npm run test:tenants && npm run test:activation && npm run test:events && npm run test:workflows && npm run test:billing && npm run test:generated-repair && npm run test:site-links"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.13",
    "@ai-sdk/google": "^1.1.11",
    "@ai-sdk/groq": "^1.1.11",
    "@ai-sdk/openai": "^1.1.13",
    "@langchain/langgraph": "^0.2.32",
    "@mendable/firecrawl-js": "^1.15.0",
    "ai": "^4.1.25",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "langfuse": "^3.33.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
