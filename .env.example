# =============================================================================
# Dynasty Launcher / Your Deputy — Environment Variables
# =============================================================================
# Copy to .env and fill in real values. All STUB_ prefixed values are
# placeholders that enable local dev with stub providers.
# =============================================================================

# --- Core Platform ---
VERCEL_URL=https://yourdeputy.com
APP_URL=https://yourdeputy.com
CORS_ORIGIN=https://yourdeputy.com
NODE_ENV=production
AUTOMATION_ONLY_MODE=false

# --- Database (PostgreSQL via Neon or self-hosted) ---
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:pass@neon.tech/dbname?sslmode=require
NEON_STORE_ID=postgresql://user:pass@neon.tech/dbname?sslmode=require
NEON_API_KEY=neon_api_key_here
POSTGRES_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- Authentication & Secrets ---
ADMIN_KEY=change-me-to-random-secure-key
TEST_ADMIN_KEY=test-key-dev-only
JWT_SECRET=change-me-to-random-64-char-secret
SESSION_SECRET=change-me-to-random-64-char-secret
ADMIN_TOKEN=admin-token-here
DYNASTY_ADMIN_TOKEN=dynasty-admin-token

# --- Business Information ---
BUSINESS_NAME=Your Deputy
BUSINESS_DOMAIN=yourdeputy.com
BUSINESS_PHONE=+1-555-0000
ADMIN_EMAIL=admin@yourdeputy.com
OWNER_EMAIL=owner@yourdeputy.com

# =============================================================================
# --- Email Providers ---
# =============================================================================
# Use STUB_ values for local dev, real keys for production

RESEND_KEY=STUB_resend
RESEND_API_KEY=STUB_resend
SENDGRID_API_KEY=STUB_sendgrid
RECOVERY_EMAIL_FROM=Your Deputy <hello@yourdeputy.com>
RECOVERY_EMAIL_FROM_ADDRESS=hello@yourdeputy.com
RECOVERY_EMAIL_FROM_NAME=Your Deputy
ACUMBAMAIL_KEY=STUB_acumbamail
ACUMBAMAIL_USER=STUB_acumbamail_user
ACUMBAMAIL_PASS=STUB_acumbamail_pass
ACUMBAMAIL_API_KEY=STUB_acumbamail_api
EMAILIT_API_KEY=STUB_emailit

# =============================================================================
# --- SMS & Communication ---
# =============================================================================

SMSIT_KEY=STUB_smsit
SMS_IT_API_KEY=STUB_smsit
SMSIT_API_KEY=STUB_smsit
TWILIO_ACCOUNT_SID=STUB_twilio_sid
TWILIO_AUTH_TOKEN=STUB_twilio_token
TELEGRAM_BOT_TOKEN=STUB_telegram_bot_token
TELEGRAM_CHAT_ID=STUB_telegram_chat_id

# =============================================================================
# --- Phone & Call Handling ---
# =============================================================================

CALLSCALER_API_KEY=STUB_callscaler
CALLSCALER_WEBHOOK_SECRET=STUB_callscaler_webhook_secret
PULSETIC_API_KEY=STUB_pulsetic

# =============================================================================
# --- Calendar & Scheduling ---
# =============================================================================

TRAFFT_API_KEY=STUB_trafft
TRAFFT_WEBHOOK_SECRET=STUB_trafft_webhook_secret

# =============================================================================
# --- AI / LLM Providers ---
# =============================================================================

OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=whisper-1
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_KEY=STUB_google_ai
GROQ_API_KEY=STUB_groq
MISTRAL_API_KEY=STUB_mistral
DEEPSEEK_API_KEY=STUB_deepseek
SAMBANOVA_API_KEY=STUB_sambanova
CEREBRAS_API_KEY=STUB_cerebras
OPENROUTER_API_KEY=STUB_openrouter
OLLAMA_URL=http://localhost:11434

# =============================================================================
# --- Automation & n8n ---
# =============================================================================

N8N_API_URL=http://localhost:5678
N8N_API_KEY=n8n_api_key_here

# =============================================================================
# --- Payments & Billing ---
# =============================================================================

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...
PAYMENT_ACCESS_SECRET=payment_secret_key

# --- Pricing Limits (for free tier) ---
FREE_GUEST_SCORING_LIMIT=10
FREE_REGISTERED_SCORING_LIMIT=100
FREE_SCORING_DAILY_LIMIT=500
SCORING_PRO_MONTHLY_LIMIT=10000

# =============================================================================
# --- Cloud Hosting & Infrastructure ---
# =============================================================================

VERCEL_API_TOKEN=vercel_token_here
TWENTYI_API_KEY=twentyi_api_key_here

# --- Google Cloud (GCP) ---
GCP_PROJECT_ID=gcp-project-id
GCP_KEY_FILE=/path/to/gcp-key.json

# --- AWS (if used) ---
# AWS_ACCESS_KEY_ID=aws_key
# AWS_SECRET_ACCESS_KEY=aws_secret

# =============================================================================
# --- Git Integration ---
# =============================================================================

GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org-name

# =============================================================================
# --- Authentication Providers (Optional) ---
# =============================================================================

CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# --- Reviews & Reputation Management ---
# =============================================================================

# Google Business Profile
GOOGLE_BUSINESS_PROFILE_KEY=STUB_gbp

# --- Third-party Review/Rating Services ---
# HAPPIERLEADS_API_KEY=STUB_happierleads
# SALESPANEL_API_KEY=STUB_salespanel
# PULSETIC_API_KEY=STUB_pulsetic

# =============================================================================
# --- Webhooks & Event Routing ---
# =============================================================================

WEBHOOK_SECRET=webhook_secret_key
FORMS_WEBHOOK_SECRET=forms_webhook_secret
CRMEVENT_WEBHOOK_SECRET=crmevent_webhook_secret

# --- Webhook URLs (outbound) ---
FORMS_WEBHOOK_URL=https://yourdeputy.com/webhooks/forms
CRMEVENT_WEBHOOK_URL=https://yourdeputy.com/webhooks/crmevent

# =============================================================================
# --- Data & Research Tools ---
# =============================================================================

CLEARBIT_API_KEY=STUB_clearbit
HUNTER_API_KEY=STUB_hunter
EXA_AI_API_KEY=STUB_exa_ai
OUTSCRAPER_API_KEY=STUB_outscraper
HEXOMATIC_API_KEY=STUB_hexomatic
STACKSHARE_API_KEY=STUB_stackshare

# =============================================================================
# --- Document & Legal Processing ---
# =============================================================================

HELLOSIGN_API_KEY=STUB_hellosign
INCFILE_API_KEY=STUB_incfile
LEGALZOOM_API_KEY=STUB_legalzoom
IRS_API_KEY=STUB_irs
DOCUMENTERO_API_KEY=STUB_documentero
BRILLIANT_API_KEY=STUB_brilliant

# =============================================================================
# --- CRM & Business Management ---
# =============================================================================

SUITEDASH_API_KEY=STUB_suitedash
SUITEDASH_PUBLIC_ID=STUB_suitedash_public
SUITEDASH_SECRET_KEY=STUB_suitedash_secret

# =============================================================================
# --- Content & Video Generation ---
# =============================================================================

FLIKI_API_KEY=STUB_fliki
VISTA_SOCIAL_API_KEY=STUB_vista_social
INSIGHTO_API_KEY=STUB_insighto
NEURONWRITER_API_KEY=STUB_neuronwriter
CLAIMSMATE_API_KEY=STUB_claimsmate
VADOO_API_KEY=STUB_vadoo
SUPERMACHINE_API_KEY=STUB_supermachine
CHATBASE_API_KEY=STUB_chatbase

# =============================================================================
# --- Analytics & Monitoring ---
# =============================================================================

POSTHOG_API_KEY=STUB_posthog
POSTHOG_HOST=https://posthog.yourdeputy.com

# --- Maps ---
GOOGLE_MAPS_API_KEY=STUB_google_maps

# =============================================================================
# --- Dynasty Platform Configuration (Composite Config Object) ---
# =============================================================================
# This JSON object centralizes provider credentials for internal routing.
# Format: {"section": {"key": "value", ...}, ...}
# Used by api/admin.js for centralized credential management.

DYNASTY_TOOL_CONFIG={"comms":{"acumbamail":"STUB","resend":"STUB","smsit":"STUB","email_from":"notifications@yourdeputy.com","email_from_name":"Your Deputy"},"automation":{"n8n_api":"n8n_api_key","n8n_url":"http://localhost:5678"},"payments":{"stripe_live":"sk_test_..."},"infrastructure":{"vercel":"vercel_token","twentyi_general":"twentyi_key"}}

# =============================================================================
# --- Feature Flags ---
# =============================================================================

ENABLE_STUB_PROVIDERS=true
ENABLE_AUTOMATION_CATALOG=true
PROVISION_TIER_TRUST_CLIENT=0
SEND_THANK_YOU_EMAIL=true

# =============================================================================
# --- Supabase (Optional, if using as auth/storage) ---
# =============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=supabase_anon_key

# =============================================================================
# --- Analytics & Frontend ---
# =============================================================================

NEXT_PUBLIC_APP_URL=https://yourdeputy.com
FRONTEND_URL=https://yourdeputy.com
BASE_URL=https://yourdeputy.com
DOMAIN=yourdeputy.com

# =============================================================================
# --- Notes ---
# =============================================================================
#
# 1. REQUIRED for production:
#    - DATABASE_URL (or NEON_STORE_ID)
#    - ANTHROPIC_API_KEY
#    - JWT_SECRET, SESSION_SECRET (strong random values)
#    - ADMIN_KEY (for admin endpoints)
#    - VERCEL_URL / APP_URL (points to production domain)
#
# 2. OPTIONAL (development):
#    - Use STUB_ values for any provider you're not actively testing
#    - Leave blank if integration not needed
#
# 3. STRIPE integration:
#    - STRIPE_SECRET_KEY required for billing/checkout
#    - STRIPE_WEBHOOK_SECRET required for webhook verification
#
# 4. n8n workflows:
#    - N8N_API_URL and N8N_API_KEY for workflow imports
#    - Run: node scripts/n8n-import.mjs
#
# 5. Secrets (rotate regularly):
#    - Generate random 64-char strings for JWT_SECRET, SESSION_SECRET
#    - Use strong ADMIN_KEY (min 32 chars, alphanumeric + symbols)
#    - Never commit real .env to git; use .env.example only
#
# =============================================================================
