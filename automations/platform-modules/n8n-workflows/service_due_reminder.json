{
  "name": "Service Due Reminder (CRON)",
  "nodes": [
    {
      "parameters": {
        "mode": "every",
        "interval": [1],
        "triggerAtStartup": false
      },
      "id": "cron_daily",
      "name": "Daily CRON (8am)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "{{ $env.VERCEL_API_URL }}/crm/customers/due-for-service?days=30"
      },
      "id": "get_30day_due",
      "name": "Get 30-Day Due Customers",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 150]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "{{ $env.VERCEL_API_URL }}/crm/customers/due-for-service?days=14"
      },
      "id": "get_14day_due",
      "name": "Get 14-Day Due Customers",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "{{ $env.VERCEL_API_URL }}/crm/customers/due-for-service?days=7"
      },
      "id": "get_7day_due",
      "name": "Get 7-Day Due Customers",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 450]
    },
    {
      "parameters": {
        "resource": "list",
        "operation": "batch"
      },
      "id": "send_30day_emails",
      "name": "Send 30-Day Reminders",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [650, 150]
    },
    {
      "parameters": {
        "resource": "list",
        "operation": "batch"
      },
      "id": "send_14day_emails",
      "name": "Send 14-Day Reminders",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "resource": "list",
        "operation": "batch"
      },
      "id": "send_7day_sms",
      "name": "Send 7-Day SMS",
      "type": "n8n-nodes-base.sms",
      "typeVersion": 1,
      "position": [650, 450]
    }
  ],
  "connections": {
    "cron_daily": {
      "main": [[{"node": "get_30day_due", "type": "main", "index": 0}, {"node": "get_14day_due", "type": "main", "index": 0}, {"node": "get_7day_due", "type": "main", "index": 0}]]
    },
    "get_30day_due": {
      "main": [[{"node": "send_30day_emails", "type": "main", "index": 0}]]
    },
    "get_14day_due": {
      "main": [[{"node": "send_14day_emails", "type": "main", "index": 0}]]
    },
    "get_7day_due": {
      "main": [[{"node": "send_7day_sms", "type": "main", "index": 0}]]
    }
  }
}
