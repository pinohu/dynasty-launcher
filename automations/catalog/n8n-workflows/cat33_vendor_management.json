    "Check Contract Expiry": {
      "main": [
        [
          {
            "node": "Check If Expiring Soon",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check If Expiring Soon": {
      "main": [
        [
          {
            "node": "Send Expiry Notification",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Unprocessed Invoices": {
      "main": [
        [
          {
