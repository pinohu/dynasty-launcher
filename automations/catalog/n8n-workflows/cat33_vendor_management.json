    "Process Each Invoice": {
      "main": [
        [
          {
            "node": "Extract Invoice Data via AI",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Invoice Data via AI": {
      "main": [
        [
          {
            "node": "Mark Invoice Processed",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Calculate Vendor Scores": {
      "main": [
        [
          {
            "node": "Store Scores",
            "type": "main",
            "index": 0
          }
        ]
      ]
