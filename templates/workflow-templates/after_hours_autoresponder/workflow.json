{
  "schema_version": "1.0.0",
  "module_code": "after_hours_autoresponder",
  "name": "After-Hours Auto-Responder Workflow",
  "description": "Production workflow for After-Hours Auto-Responder: When leads come in outside business hours, send a response that sets expectations and offers self-booking.",
  "trigger": {
    "event": "lead.created",
    "conditions": {
      "outside_business_hours": true
    }
  },
  "actions": [
    {
      "step": 1,
      "action": "send_sms",
      "params": {
        "template_ref": "tmpl_after_hours_autoresponder_sms",
        "to": "payload.phone"
      }
    },
    {
      "step": 2,
      "action": "send_email",
      "params": {
        "template_ref": "tmpl_after_hours_autoresponder_email",
        "to": "payload.email"
      }
    },
    {
      "step": 3,
      "action": "offer_booking_link",
      "params": {}
    },
    {
      "step": 4,
      "action": "tag_contact",
      "params": {
        "tags": [
          "after-hours-autoresponder"
        ]
      }
    }
  ],
  "observability": {
    "emit_on_start": "module.run.started",
    "emit_on_complete": "module.run.completed",
    "emit_on_fail": "module.run.failed"
  },
  "version": "1.0.0"
}
