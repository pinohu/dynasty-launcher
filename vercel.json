{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/claude.js": { "maxDuration": 300 },
    "api/github.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" }
      ]
    }
  ]
}
