{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "yourdeputy.com" }],
      "destination": "https://www.yourdeputy.com/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/claude.js": {
      "maxDuration": 300
    },
    "api/github.js": {
      "maxDuration": 30
    },
    "api/provision.js": {
      "maxDuration": 300,
      "includeFiles": "api/automation-catalog.js"
    },
    "api/catalog/modules.js": {
      "maxDuration": 10,
      "includeFiles": "product/**/*.json"
    },
    "api/catalog/bundles.js": {
      "maxDuration": 10,
      "includeFiles": "product/**/*.json"
    },
    "api/catalog/blueprints.js": {
      "maxDuration": 10,
      "includeFiles": "product/**/*.json"
    },
    "api/catalog/personas.js": {
      "maxDuration": 10,
      "includeFiles": "product/**/*.json"
    },
    "api/catalog/tiers.js": {
      "maxDuration": 10,
      "includeFiles": "product/**/*.json"
    },
    "api/tenants/create-tenant.js": {
      "maxDuration": 15,
      "includeFiles": "product/**/*.json"
    },
    "api/tenants/get-tenant.js": {
      "maxDuration": 10
    },
    "api/tenants/get-tenant-capabilities.js": {
      "maxDuration": 10,
      "includeFiles": "product/**/*.json"
    },
    "api/tenants/set-tenant-capability.js": {
      "maxDuration": 10,
      "includeFiles": "product/**/*.json"
    },
    "api/tenants/activate-module.js": {
      "maxDuration": 30,
      "includeFiles": "product/**/*.json"
    },
    "api/tenants/deactivate-module.js": {
      "maxDuration": 15,
      "includeFiles": "product/**/*.json"
    },
    "api/tenants/grant-entitlement.js": {
      "maxDuration": 15,
      "includeFiles": "product/**/*.json"
    },
    "api/events/ingest-event.js": {
      "maxDuration": 30,
      "includeFiles": "{product/**/*.json,templates/workflow-templates/**/*.json}"
    },
    "api/events/opportunity-cards.js": {
      "maxDuration": 15,
      "includeFiles": "product/**/*.json"
    },
    "api/tenants/install-blueprint.js": {
      "maxDuration": 30,
      "includeFiles": "product/**/*.json"
    },
    "api/billing/create-checkout-session.js": {
      "maxDuration": 30,
      "includeFiles": "product/**/*.json"
    },
    "api/billing/webhook.js": {
      "maxDuration": 30,
      "includeFiles": "product/**/*.json"
    },
    "api/admin/test-fire-event.js": {
      "maxDuration": 30,
      "includeFiles": "{product/**/*.json,templates/workflow-templates/**/*.json}"
    },
    "api/health.js": {
      "maxDuration": 15
    },
    "api/twentyi.js": {
      "maxDuration": 60
    },
    "api/neon.js": {
      "maxDuration": 60
    },
    "api/validate.js": {
      "maxDuration": 15
    },
    "api/ai.js": {
      "maxDuration": 300
    },
    "api/orchestrate.js": {
      "maxDuration": 300
    },
    "api/memory.js": {
      "maxDuration": 30
    },
    "api/flags.js": {
      "maxDuration": 10
    },
    "api/research.js": {
      "maxDuration": 60
    },
    "api/auth.js": {
      "maxDuration": 30
    },
    "api/admin.js": {
      "maxDuration": 60
    },
    "api/checkout.js": {
      "maxDuration": 30
    },
    "api/waitlist.js": {
      "maxDuration": 15
    },
    "api/telemetry.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://yourdeputy.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://api.anthropic.com https://api.groq.com https://openrouter.ai https://api.stripe.com https://api.deepseek.com https://generativelanguage.googleapis.com https://api.mistral.ai; img-src 'self' data: blob: https://riku-assets.com; frame-src https://js.stripe.com https://accounts.google.com; media-src blob:"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://api.anthropic.com https://api.groq.com https://openrouter.ai https://api.stripe.com https://api.deepseek.com https://generativelanguage.googleapis.com https://api.mistral.ai; img-src 'self' data: blob: https://riku-assets.com; frame-src https://js.stripe.com https://accounts.google.com; media-src blob:" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}