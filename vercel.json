{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/claude.js": {
      "maxDuration": 300
    },
    "api/github.js": {
      "maxDuration": 30
    },
    "api/provision.js": {
      "maxDuration": 300
    },
    "api/health.js": {
      "maxDuration": 15
    },
    "api/twentyi.js": {
      "maxDuration": 60
    },
    "api/neon.js": {
      "maxDuration": 60
    },
    "api/validate.js": {
      "maxDuration": 15
    },
    "api/ai.js": {
      "maxDuration": 300
    },
    "api/orchestrate.js": {
      "maxDuration": 300
    },
    "api/memory.js": {
      "maxDuration": 30
    },
    "api/flags.js": {
      "maxDuration": 10
    },
    "api/research.js": {
      "maxDuration": 60
    },
    "api/auth.js": {
      "maxDuration": 30
    },
    "api/admin.js": {
      "maxDuration": 60
    },
    "api/checkout.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://yourdeputy.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://api.anthropic.com https://api.groq.com https://openrouter.ai https://api.stripe.com; img-src 'self' data: blob:; frame-src https://js.stripe.com https://accounts.google.com"
        }
      ]
    }
  ]
}