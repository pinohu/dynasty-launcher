{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/claude.js": {
      "maxDuration": 300
    },
    "api/github.js": {
      "maxDuration": 30
    },
    "api/provision.js": {
      "maxDuration": 300
    },
    "api/health.js": {
      "maxDuration": 15
    },
    "api/twentyi.js": {
      "maxDuration": 60
    },
    "api/neon.js": {
      "maxDuration": 60
    },
    "api/validate.js": {
      "maxDuration": 15
    },
    "api/ai.js": {
      "maxDuration": 300
    },
    "api/orchestrate.js": {
      "maxDuration": 300
    },
    "api/memory.js": {
      "maxDuration": 30
    },
    "api/flags.js": {
      "maxDuration": 10
    },
    "api/research.js": {
      "maxDuration": 60
    },
    "api/auth.js": {
      "maxDuration": 30
    },
    "api/checkout.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://dynasty-launcher.vercel.app"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}