{
  "schema_version": "1.0.0",
  "unit_type": "edition",
  "unit_code": "enterprise",
  "title": "Enterprise / Multi-Location Demo",
  "route": "/demo/editions/enterprise",
  "demo_trigger": "edition.demo",
  "sample_input": {
    "unit_type": "edition",
    "unit_code": "enterprise"
  },
  "module_codes": [
    "missed_call_textback",
    "webform_autoreply",
    "instant_lead_ack",
    "post_job_review_request",
    "unhappy_customer_interception",
    "advanced_reporting",
    "appointment_confirmation",
    "appointment_reminder",
    "no_show_recovery",
    "dormant_customer_reactivation",
    "service_due_reminder",
    "invoice_sent_notification",
    "overdue_invoice_reminder",
    "payment_recovery"
  ],
  "expected_events": [
    "demo.session_created",
    "demo.unit_ran",
    "call.missed",
    "form.submitted",
    "lead.created",
    "job.completed",
    "review_request.reply",
    "report.requested",
    "appointment.created",
    "appointment.upcoming",
    "appointment.no_show",
    "customer.dormant",
    "service.due",
    "invoice.sent",
    "invoice.overdue",
    "payment.failed"
  ],
  "expected_outputs": [
    "visible_execution_trace",
    "sandbox_output_preview",
    "activation_proof",
    "cta_to_activate",
    "catalog_traceability"
  ],
  "cta": "Choose Enterprise / Multi-Location",
  "api": {
    "create_session": "POST /api/demo/create-session",
    "run": "POST /api/demo/run-module",
    "trace": "GET /api/demo/trace?run_id={run_id}"
  },
  "validation": {
    "must_execute": true,
    "must_return_trace": true,
    "must_not_require_real_vendor_credentials": true
  }
}
