{
  "schema_version": "1.0.0",
  "module_code": "missed_call_textback",
  "name": "Missed Call Text-Back",
  "description_short": "When a call is missed, automatically text the caller back within seconds.",
  "outcome": "Recover revenue from missed phone leads without adding staff.",
  "category": "lead-capture",
  "price_monthly": 19,
  "tier_availability": [
    "professional",
    "enterprise"
  ],
  "capabilities_required": [
    "phone",
    "sms",
    "crm"
  ],
  "prerequisite_modules": [],
  "compliance_flags": [
    "sms_opt_out",
    "quiet_hours",
    "a2p_registered"
  ],
  "activation_type": "guided",
  "trigger": {
    "event": "call.missed",
    "conditions": {
      "caller_is_new_or_unknown": true
    }
  },
  "inputs": [
    "call_event",
    "business_profile",
    "default_reply_template"
  ],
  "actions": [
    "send_sms",
    "create_lead",
    "tag_contact",
    "notify_owner"
  ],
  "configurable_settings": [
    {
      "key": "reply_delay_seconds",
      "label": "Reply delay (seconds)",
      "type": "int",
      "default": 30
    },
    {
      "key": "quiet_hours",
      "label": "Quiet hours",
      "type": "schedule"
    },
    {
      "key": "template_id",
      "label": "SMS template",
      "type": "template_ref",
      "default": "tmpl_missed_call_default"
    },
    {
      "key": "assigned_owner",
      "label": "Route lead to",
      "type": "user_ref"
    },
    {
      "key": "only_business_hours",
      "label": "Only send during business hours",
      "type": "bool",
      "default": false
    }
  ],
  "templates_used": [
    "tmpl_missed_call_default",
    "tmpl_after_hours_callback"
  ],
  "recommended_for_personas": [
    "owner-operator",
    "office-manager"
  ],
  "recommended_for_blueprints": [
    "plumbing",
    "hvac",
    "electrical",
    "pest-control",
    "cleaning"
  ],
  "upsell_from": [],
  "upsell_to": [
    "instant_lead_ack",
    "voicemail_transcription",
    "after_hours_autoresponder"
  ],
  "kpis": [
    "missed_calls_recovered",
    "responses_sent",
    "bookings_from_recovery"
  ],
  "downgrade_behavior": {
    "on_cancel": "disable_new_runs_keep_data",
    "data_retention_days": 365
  },
  "source_refs": [
    "2.02",
    "2.15",
    "14.XX"
  ],
  "status": "live",
  "deployment_state": "active",
  "marketplace_ready": true,
  "ready_for_use": true,
  "production_ready_on": "2026-04-25"
}
