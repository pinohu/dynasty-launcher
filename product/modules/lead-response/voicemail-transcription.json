{
  "schema_version": "1.0.0",
  "module_code": "voicemail_transcription",
  "name": "Voicemail Transcription to CRM",
  "description_short": "Every voicemail is transcribed, saved on the contact record, and surfaced to the right staffer.",
  "outcome": "Nothing said on voicemail gets lost or re-listened to by three different people.",
  "category": "lead-response",
  "price_monthly": 19,
  "tier_availability": [
    "professional",
    "enterprise"
  ],
  "capabilities_required": [
    "phone",
    "crm"
  ],
  "prerequisite_modules": [],
  "compliance_flags": [
    "pii_minimization",
    "call_recording_consent"
  ],
  "activation_type": "instant",
  "trigger": {
    "event": "voicemail.received"
  },
  "inputs": [
    "voicemail_audio",
    "contact_record"
  ],
  "actions": [
    "transcribe",
    "attach_to_contact",
    "notify_owner",
    "auto_tag_intent"
  ],
  "configurable_settings": [
    {
      "key": "notify_channel",
      "label": "Notify via",
      "type": "enum",
      "options": [
        "sms",
        "email",
        "slack"
      ],
      "default": "sms"
    },
    {
      "key": "intent_tags",
      "label": "Auto-tag intents",
      "type": "bool",
      "default": true
    }
  ],
  "templates_used": [
    "tmpl_voicemail_alert"
  ],
  "recommended_for_personas": [
    "office-manager",
    "owner-operator"
  ],
  "recommended_for_blueprints": [
    "plumbing",
    "hvac",
    "electrical",
    "pest-control"
  ],
  "upsell_from": [
    "missed_call_textback"
  ],
  "upsell_to": [
    "speed_to_lead_response"
  ],
  "kpis": [
    "voicemail_response_time",
    "voicemails_to_bookings"
  ],
  "downgrade_behavior": {
    "on_cancel": "disable_and_archive",
    "data_retention_days": 180
  },
  "source_refs": [
    "2.09"
  ],
  "status": "live",
  "deployment_state": "active",
  "marketplace_ready": true,
  "ready_for_use": true,
  "production_ready_on": "2026-04-25"
