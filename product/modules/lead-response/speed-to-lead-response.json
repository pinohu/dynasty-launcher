{
  "schema_version": "1.0.0",
  "module_code": "speed_to_lead_response",
  "name": "Speed-to-Lead Dispatcher",
  "description_short": "Route new leads to the right person in under 60 seconds with SMS/call cascades until someone accepts.",
  "outcome": "Every lead gets a human touch while intent is hottest.",
  "category": "lead-response",
  "price_monthly": 19,
  "tier_availability": [
    "professional",
    "enterprise"
  ],
  "capabilities_required": [
    "crm",
    "sms",
    "phone"
  ],
  "prerequisite_modules": [],
  "compliance_flags": [
    "sms_opt_out",
    "quiet_hours"
  ],
  "activation_type": "guided",
  "trigger": {
    "event": "lead.created"
  },
  "inputs": [
    "lead_record",
    "staff_roster",
    "routing_rules"
  ],
  "actions": [
    "ping_staff",
    "escalate_on_no_accept",
    "log_dispatch_chain",
    "send_customer_update"
  ],
  "configurable_settings": [
    {
      "key": "accept_window_seconds",
      "label": "Accept window per staffer (seconds)",
      "type": "int",
      "default": 60
    },
    {
      "key": "escalation_order",
      "label": "Escalation order",
      "type": "string",
      "default": "primary,secondary,owner"
    },
    {
      "key": "fallback_channel",
      "label": "If no one accepts",
      "type": "enum",
      "options": [
        "group_blast",
        "ring_all",
        "owner_only"
      ],
      "default": "owner_only"
    }
  ],
  "templates_used": [
    "tmpl_dispatch_new_lead"
  ],
  "recommended_for_personas": [
    "office-manager",
    "owner-operator",
    "sales-coordinator"
  ],
  "recommended_for_blueprints": [
    "plumbing",
    "hvac",
    "electrical"
  ],
  "upsell_from": [
    "instant_lead_ack"
  ],
  "upsell_to": [
    "estimate_followup"
  ],
  "kpis": [
    "time_to_human_touch_p95",
    "lead_accept_rate",
    "owner_escalations"
  ],
  "downgrade_behavior": {
    "on_cancel": "disable_new_runs_keep_data",
    "data_retention_days": 365
  },
  "source_refs": [
    "5.01",
    "5.07"
  ],
  "status": "spec"
}
