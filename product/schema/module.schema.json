{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yourdeputy.com/product/schema/module.schema.json",
  "title": "Module",
  "description": "A sellable micro-SaaS unit. One module = one outcome a customer can activate.",
  "type": "object",
  "required": [
    "module_code",
    "name",
    "category",
    "outcome",
    "price_monthly",
    "capabilities_required",
    "activation_type",
    "trigger",
    "actions"
  ],
  "properties": {
    "schema_version": { "type": "string", "default": "1.0.0" },
    "module_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "name": { "type": "string" },
    "description_short": { "type": "string" },
    "description_long": { "type": "string" },
    "outcome": { "type": "string", "description": "The business result in one sentence." },
    "category": {
      "type": "string",
      "enum": [
        "lead-capture",
        "lead-response",
        "sales",
        "scheduling",
        "communication",
        "reviews",
        "billing",
        "retention",
        "reporting",
        "team",
        "intake",
        "estimates"
      ]
    },
    "price_monthly": { "type": "number", "minimum": 0 },
    "tier_availability": {
      "type": "array",
      "description": "Which launcher build tiers can subscribe to this module. Aligns with TIER_MODULES in api/provision.js. Omit or empty = available to all tiers.",
      "items": { "type": "string", "enum": ["foundation", "professional", "enterprise"] },
      "uniqueItems": true
    },
    "capabilities_required": {
      "type": "array",
      "items": { "type": "string" }
    },
    "capabilities_optional": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prerequisite_modules": {
      "type": "array",
      "description": "Other modules whose events this module depends on. Enforced at activation time.",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "compliance_flags": {
      "type": "array",
      "description": "Policy gates the activation UI and runtime must respect (e.g. sms_opt_out, quiet_hours, email_footer, can_spam, pci_hand_off, review_solicitation_policy, pii_minimization, fdcpa_b2b_tone_guard, a2p_registered, call_recording_consent).",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "activation_type": {
      "type": "string",
      "enum": ["instant", "guided", "assisted"]
    },
    "trigger": {
      "type": "object",
      "required": ["event"],
      "properties": {
        "event": { "type": "string" },
        "conditions": { "type": "object" }
      }
    },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "actions": { "type": "array", "items": { "type": "string" } },
    "configurable_settings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "label", "type"],
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string", "enum": ["string", "int", "float", "bool", "enum", "duration", "template_ref", "user_ref", "schedule"] },
          "default": {},
          "options": { "type": "array" }
        }
      }
    },
    "templates_used": { "type": "array", "items": { "type": "string" } },
    "recommended_for_personas": { "type": "array", "items": { "type": "string" } },
    "recommended_for_blueprints": { "type": "array", "items": { "type": "string" } },
    "upsell_from": { "type": "array", "items": { "type": "string" } },
    "upsell_to": { "type": "array", "items": { "type": "string" } },
    "kpis": { "type": "array", "items": { "type": "string" } },
    "downgrade_behavior": {
      "type": "object",
      "description": "What happens when the customer cancels or downgrades off this module. Preserves data unless explicitly archived.",
      "additionalProperties": false,
      "properties": {
        "on_cancel": {
          "type": "string",
          "enum": ["disable_new_runs_keep_data", "disable_and_archive", "manual_review"]
        },
        "data_retention_days": { "type": "integer", "minimum": 0 }
      }
    },
    "owner_notes": {
      "type": "string",
      "description": "Internal notes for the catalog team. Not shown to customers."
    },
    "source_refs": {
      "type": "array",
      "description": "Back-references to rows in SERVICE_BUSINESS_AUTOMATION_CATALOG.md (e.g. '2.15').",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["live", "beta", "spec", "deprecated"],
      "default": "spec"
    }
  },
  "additionalProperties": false
}
