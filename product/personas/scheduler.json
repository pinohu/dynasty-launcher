{
  "schema_version": "1.0.0",
  "persona_code": "scheduler",
  "name": "Scheduler / Dispatcher",
  "role": "Owns the calendar: booking, confirming, reminding, rerouting",
  "persona_group_ref": "group-1:scheduler",
  "pains": [
    "last-minute cancellations",
    "no-show days",
    "double-bookings across staff",
