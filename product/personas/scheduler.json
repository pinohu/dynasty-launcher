    "fewer inbound 'what time was my appointment' calls",
    "predictable crew utilization"
  ],
  "preferred_channels": ["sms", "email"],
  "messaging_tone": "crisp, polite, schedule-first",
  "default_module_recommendations": [
    "appointment_confirmation",
    "appointment_reminder",
    "reschedule_workflow",
    "no_show_recovery"
  ],
  "default_bundle_recommendations": ["scheduling_pack"],
  "typical_business_size": "5–30 staff, $1M–$10M revenue",
  "success_signals": ["no_show_rate", "self_serve_reschedule_rate", "crew_utilization"]
}
